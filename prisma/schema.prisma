// iVendorz — Prisma schema (Wave 0 bootstrap).
//
// One PostgreSQL schema per module (Doc-2; one Prisma namespace per module, Doc-6A R3(b)).
// multiSchema is GA in Prisma 6 — the 10 module namespaces are declared here; their tables
// (models) are realized per module in later waves per the frozen Doc-6B…6K DDL.
// NO business models at bootstrap — coin nothing; models land with their owning module.
//
// Codegen output lands in generated-contracts-registry/ — GENERATED, gitignored,
// never hand-edited (Doc-6A §11.4; CLAUDE.md §10).
//
// Namespace → module → DB doc:
//   core          M0 Platform Core / Shared Kernel  Doc-6B
//   identity      M1 Identity & Organization        Doc-6C
//   marketplace   M2 Marketplace & Discovery        Doc-6D
//   rfq           M3 RFQ Procurement Engine (moat)  Doc-6E
//   operations    M4 Business Operations            Doc-6F
//   trust         M5 Trust & Verification           Doc-6G
//   communication M6 Communication                  Doc-6H
//   billing       M7 Monetization                   Doc-6I
//   admin         M8 Admin Operations               Doc-6J
//   ai            M9 AI Layer (reserved)            Doc-6K

generator client {
  provider = "prisma-client-js"
  output   = "../generated-contracts-registry/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
  schemas   = ["core", "identity", "marketplace", "rfq", "operations", "trust", "communication", "billing", "admin", "ai"]
}

// ─────────────────────────────────────────────────────────────────────────────
// M0 — Platform Core / Shared Kernel (`core`) — Doc-6B (FROZEN)
//
// The 5 platform-owned tables (Doc-2 §10.1), realized verbatim from Doc-6B
// Content Pass-1/Pass-2. Columns are [Doc-2 binding]; physical types/names are
// [§2.5] realization choices, tagged in Doc-6B. Triggers, the
// `core.allocate_human_ref` SECURITY DEFINER function, RLS, and the 18-key
// POLICY seed are NOT representable in Prisma — they are raw SQL in the
// `core_init` migration (Doc-6B §5.1; tables managed by Prisma).
// ─────────────────────────────────────────────────────────────────────────────

// §3.1 — core.audit_records (immutable audit stream; CR3 PK = audit_id, CR4′ column-scoped)
model AuditRecord {
  auditId        String    @id @map("audit_id") @db.Uuid
  actorId        String?   @map("actor_id") @db.Uuid
  actorType      ActorType @map("actor_type")
  organizationId String?   @map("organization_id") @db.Uuid
  entityType     String    @map("entity_type")
  entityId       String    @map("entity_id") @db.Uuid
  action         String
  oldValue       Json?     @map("old_value") @db.JsonB
  newValue       Json?     @map("new_value") @db.JsonB
  eventTime      DateTime  @map("event_time") @db.Timestamptz
  ipAddress      String?   @map("ip_address") @db.Inet
  userAgent      String?   @map("user_agent")
  archivedAt     DateTime? @map("archived_at") @db.Timestamptz
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  @@index([organizationId, eventTime], map: "audit_records_org_time_idx")
  @@index([entityType, entityId, eventTime], map: "audit_records_entity_time_idx")
  @@map("audit_records")
  @@schema("core")
}

enum ActorType {
  user
  admin
  system
  ai_agent

  @@schema("core")
}

// §3.2 — core.outbox_events (transactional outbox; CR5 status column, CR4′ forward-only)
model OutboxEvent {
  id           String       @id @db.Uuid
  aggregateId  String?      @map("aggregate_id") @db.Uuid
  eventName    String       @map("event_name")
  eventVersion Int          @map("event_version")
  payloadJsonb Json         @map("payload_jsonb") @db.JsonB
  status       OutboxStatus @default(pending)
  dispatchedAt DateTime?    @map("dispatched_at") @db.Timestamptz
  attempts     Int          @default(0)
  createdAt    DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime     @updatedAt @map("updated_at") @db.Timestamptz

  @@index([status, createdAt])
  @@map("outbox_events")
  @@schema("core")
}

enum OutboxStatus {
  pending
  dispatched
  archived

  @@schema("core")
}

// §3.3 — core.id_sequences (human-reference generator; CR3/CR6 composite PK)
model IdSequence {
  entityType String   @map("entity_type")
  year       Int
  nextValue  BigInt   @default(1) @map("next_value")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@id([entityType, year])
  @@map("id_sequences")
  @@schema("core")
}

// §3.4 — core.system_configuration (POLICY store; CR7)
model SystemConfiguration {
  id         String   @id @db.Uuid
  key        String   @unique(map: "system_configuration_key_uq")
  valueJsonb Json     @map("value_jsonb") @db.JsonB
  valueType  String   @map("value_type")
  updatedBy  String?  @map("updated_by") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@map("system_configuration")
  @@schema("core")
}

// §3.5 — core.feature_flags (rollout control, firewalled; CR8)
model FeatureFlag {
  id         String   @id @db.Uuid
  flagKey    String   @unique(map: "feature_flags_flag_key_uq") @map("flag_key")
  enabled    Boolean  @default(false)
  scopeJsonb Json?    @map("scope_jsonb") @db.JsonB
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@map("feature_flags")
  @@schema("core")
}

// ─────────────────────────────────────────────────────────────────────────────
// M1 — Identity & Organization (`identity`) — Doc-6C (FROZEN)
//
// WP-1.2 (`identity_init`) realized the 5-table minimal-valid subset of Doc-2 §10.2:
// users, organizations, roles, memberships, buyer_profiles. W2-IDN-1 (`identity_authz`)
// realizes the remaining 4 — permissions, role_permissions, organization_workflow_settings,
// delegation_grants — bringing all 9 `identity` tables (Doc-2 §10.2) to explicit existence.
//
// Columns are [Doc-2 binding] (verbatim Doc-2 §10.2); physical types/names are
// [§2.5] realization choices, tagged in Doc-6C Content Pass-1/2/3. Enums,
// partial-unique-live indexes, RLS, the inline FKs, and the system-bundle role
// seed are realized as raw SQL in the `identity_init` + `identity_authz` migrations
// (Doc-6C §6; tables/columns managed by Prisma). The 45-slug/4-bundle-composition seed
// (W2-IDN-2) is a separate data migration — NOT part of the structural realization here.
// ─────────────────────────────────────────────────────────────────────────────

// §3.1 — identity.users (platform-owned; the person record + auth boundary; DC-CR3)
model User {
  id               String     @id @db.Uuid
  authUserId       String?    @map("auth_user_id") @db.Uuid
  email            String?
  phone            String?
  twoFaJsonb       Json?      @map("two_fa_jsonb") @db.JsonB
  status           UserStatus @default(active)
  preferencesJsonb Json?      @map("preferences_jsonb") @db.JsonB
  // [Doc-2 §10.2 per Doc-2_Patch_v1.0.6 / Doc-6C_Patch_v1.0.2] optional user-chosen presentation
  // name; personal data (anonymized on departure with the §C4 set); never an identifier.
  displayName      String?    @map("display_name")
  createdAt        DateTime   @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime   @updatedAt @map("updated_at") @db.Timestamptz
  createdBy        String?    @map("created_by") @db.Uuid
  updatedBy        String?    @map("updated_by") @db.Uuid
  deletedAt        DateTime?  @map("deleted_at") @db.Timestamptz
  deletedBy        String?    @map("deleted_by") @db.Uuid
  deleteReason     String?    @map("delete_reason")

  memberships Membership[]

  @@map("users")
  @@schema("identity")
}

enum UserStatus {
  active
  suspended
  soft_deleted

  @@map("user_status")
  @@schema("identity")
}

// §3.2 — identity.organizations (the tenant root; first `human_ref`; §5.1 state machine; DC-CR5)
model Organization {
  id                String            @id @db.Uuid
  humanRef          String            @map("human_ref")
  name              String
  slug              String
  orgStatus         OrgStatus         @default(active) @map("org_status")
  hasBuyerProfile   Boolean           @default(false) @map("has_buyer_profile")
  hasVendorProfile  Boolean           @default(false) @map("has_vendor_profile")
  verificationLevel VerificationLevel @default(unverified) @map("verification_level")
  isPersonalOrg     Boolean           @default(false) @map("is_personal_org")
  createdAt         DateTime          @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime          @updatedAt @map("updated_at") @db.Timestamptz
  createdBy         String?           @map("created_by") @db.Uuid
  updatedBy         String?           @map("updated_by") @db.Uuid
  deletedAt         DateTime?         @map("deleted_at") @db.Timestamptz
  deletedBy         String?           @map("deleted_by") @db.Uuid
  deleteReason      String?           @map("delete_reason")

  memberships                    Membership[]
  roles                          Role[]
  buyerProfiles                  BuyerProfile[]
  organizationWorkflowSettings   OrganizationWorkflowSettings[]
  delegationGrantsControlling    DelegationGrant[]              @relation("DelegationGrantsControlling")
  delegationGrantsRepresentative DelegationGrant[]              @relation("DelegationGrantsRepresentative")

  @@unique([humanRef], map: "organizations_human_ref_uq")
  @@map("organizations")
  @@schema("identity")
}

enum OrgStatus {
  active
  suspended
  soft_deleted

  @@map("org_status")
  @@schema("identity")
}

enum VerificationLevel {
  unverified
  verified
  enhanced_verified

  @@map("verification_level")
  @@schema("identity")
}

// §3.4 — identity.roles (tenant-owned + platform system-bundle seeds; DC-CR2/DC-CR8)
model Role {
  id             String    @id @db.Uuid
  organizationId String?   @map("organization_id") @db.Uuid
  name           String
  isSystemBundle Boolean   @default(false) @map("is_system_bundle")
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  createdBy      String?   @map("created_by") @db.Uuid
  updatedBy      String?   @map("updated_by") @db.Uuid
  deletedAt      DateTime? @map("deleted_at") @db.Timestamptz
  deletedBy      String?   @map("deleted_by") @db.Uuid
  deleteReason   String?   @map("delete_reason")

  organization    Organization?    @relation(fields: [organizationId], references: [id], map: "roles_org_fk")
  memberships     Membership[]
  rolePermissions RolePermission[]

  @@map("roles")
  @@schema("identity")
}

// §3.3 — identity.memberships (user↔org link; §5.2 state machine; partial-unique-live; DC-CR10)
model Membership {
  id             String          @id @db.Uuid
  organizationId String          @map("organization_id") @db.Uuid
  userId         String          @map("user_id") @db.Uuid
  roleId         String          @map("role_id") @db.Uuid
  state          MembershipState @default(invited)
  department     String?
  joinedAt       DateTime?       @map("joined_at") @db.Timestamptz
  createdAt      DateTime        @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime        @updatedAt @map("updated_at") @db.Timestamptz
  createdBy      String?         @map("created_by") @db.Uuid
  updatedBy      String?         @map("updated_by") @db.Uuid
  deletedAt      DateTime?       @map("deleted_at") @db.Timestamptz
  deletedBy      String?         @map("deleted_by") @db.Uuid
  deleteReason   String?         @map("delete_reason")

  organization Organization @relation(fields: [organizationId], references: [id], map: "memberships_org_fk")
  user         User         @relation(fields: [userId], references: [id], map: "memberships_user_fk")
  role         Role         @relation(fields: [roleId], references: [id], map: "memberships_role_fk")

  @@map("memberships")
  @@schema("identity")
}

enum MembershipState {
  invited
  pending
  active
  suspended
  removed

  @@map("membership_state")
  @@schema("identity")
}

// §3.8 — identity.buyer_profiles (tenant-owned; SD=YES; FK → organizations)
model BuyerProfile {
  id                          String    @id @db.Uuid
  organizationId              String    @map("organization_id") @db.Uuid
  industry                    String?
  factoryInfoJsonb            Json?     @map("factory_info_jsonb") @db.JsonB
  deliveryLocationsJsonb      Json?     @map("delivery_locations_jsonb") @db.JsonB
  procurementPreferencesJsonb Json?     @map("procurement_preferences_jsonb") @db.JsonB
  createdAt                   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt                   DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  createdBy                   String?   @map("created_by") @db.Uuid
  updatedBy                   String?   @map("updated_by") @db.Uuid
  deletedAt                   DateTime? @map("deleted_at") @db.Timestamptz
  deletedBy                   String?   @map("deleted_by") @db.Uuid
  deleteReason                String?   @map("delete_reason")

  organization Organization @relation(fields: [organizationId], references: [id], map: "buyer_profiles_org_fk")

  @@map("buyer_profiles")
  @@schema("identity")
}

// §3.5 — identity.permissions (platform catalog; reference data; no org anchor; SD=NO)
model Permission {
  id          String          @id @db.Uuid
  slug        String
  description String?
  space       PermissionSpace
  createdAt   DateTime        @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime        @updatedAt @map("updated_at") @db.Timestamptz
  createdBy   String?         @map("created_by") @db.Uuid
  updatedBy   String?         @map("updated_by") @db.Uuid

  rolePermissions RolePermission[]

  @@unique([slug], map: "permissions_slug_uq")
  @@map("permissions")
  @@schema("identity")
}

enum PermissionSpace {
  tenant
  staff

  @@map("permission_space")
  @@schema("identity")
}

// §3.6 — identity.role_permissions (bundle composition, N:N; PK (role_id, permission_id); SD=NO —
// row removal = revoke, audited). `organizationId` [Doc-2 §10.2 binding] — not coined, §10.2 lists
// it; NULL for system-bundle composition (mirrors roles seed); no FK on organizationId (Doc-6C §3.6).
model RolePermission {
  roleId         String   @map("role_id") @db.Uuid
  permissionId   String   @map("permission_id") @db.Uuid
  organizationId String?  @map("organization_id") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz
  createdBy      String?  @map("created_by") @db.Uuid
  updatedBy      String?  @map("updated_by") @db.Uuid

  role       Role       @relation(fields: [roleId], references: [id], map: "role_permissions_role_fk")
  permission Permission @relation(fields: [permissionId], references: [id], map: "role_permissions_perm_fk")

  @@id([roleId, permissionId], map: "role_permissions_pkey")
  @@map("role_permissions")
  @@schema("identity")
}

// §3.7 — identity.organization_workflow_settings (tenant-owned; SD=YES; FK → organizations)
model OrganizationWorkflowSettings {
  id                        String          @id @db.Uuid
  organizationId            String          @map("organization_id") @db.Uuid
  rfqApprovalMode           RfqApprovalMode @default(none) @map("rfq_approval_mode")
  approvalChainJsonb        Json?           @map("approval_chain_jsonb") @db.JsonB
  financialPermissionsJsonb Json?           @map("financial_permissions_jsonb") @db.JsonB
  notificationRulesJsonb    Json?           @map("notification_rules_jsonb") @db.JsonB
  createdAt                 DateTime        @default(now()) @map("created_at") @db.Timestamptz
  updatedAt                 DateTime        @updatedAt @map("updated_at") @db.Timestamptz
  createdBy                 String?         @map("created_by") @db.Uuid
  updatedBy                 String?         @map("updated_by") @db.Uuid
  deletedAt                 DateTime?       @map("deleted_at") @db.Timestamptz
  deletedBy                 String?         @map("deleted_by") @db.Uuid
  deleteReason              String?         @map("delete_reason")

  organization Organization @relation(fields: [organizationId], references: [id], map: "ows_org_fk")

  @@map("organization_workflow_settings")
  @@schema("identity")
}

enum RfqApprovalMode {
  none
  single
  multi_step

  @@map("rfq_approval_mode")
  @@schema("identity")
}

// §3.9 — identity.delegation_grants (the dual-party aggregate; SD=YES; the only table with a
// cross-module ref — `vendorProfileId` → M2, bare UUID, NO FK — DC-CR10)
model DelegationGrant {
  id                           String                @id @db.Uuid
  controllingOrganizationId    String                @map("controlling_organization_id") @db.Uuid
  representativeOrganizationId String                @map("representative_organization_id") @db.Uuid
  vendorProfileId              String                @map("vendor_profile_id") @db.Uuid
  permissionSetJsonb           Json                  @map("permission_set_jsonb") @db.JsonB
  validFrom                    DateTime              @default(now()) @map("valid_from") @db.Timestamptz
  validTo                      DateTime?             @map("valid_to") @db.Timestamptz
  grantedBy                    String                @map("granted_by") @db.Uuid
  status                       DelegationGrantStatus @default(draft)
  createdAt                    DateTime              @default(now()) @map("created_at") @db.Timestamptz
  updatedAt                    DateTime              @updatedAt @map("updated_at") @db.Timestamptz
  createdBy                    String?               @map("created_by") @db.Uuid
  updatedBy                    String?               @map("updated_by") @db.Uuid
  deletedAt                    DateTime?             @map("deleted_at") @db.Timestamptz
  deletedBy                    String?               @map("deleted_by") @db.Uuid
  deleteReason                 String?               @map("delete_reason")

  controllingOrganization    Organization @relation("DelegationGrantsControlling", fields: [controllingOrganizationId], references: [id], map: "delegation_grants_controlling_fk")
  representativeOrganization Organization @relation("DelegationGrantsRepresentative", fields: [representativeOrganizationId], references: [id], map: "delegation_grants_representative_fk")

  @@map("delegation_grants")
  @@schema("identity")
}

enum DelegationGrantStatus {
  draft
  active
  suspended
  revoked
  expired

  @@map("delegation_grant_status")
  @@schema("identity")
}

// W2-IDN-6.5 — the M1 §B.6 command-dedup / Idempotency-Key replay store (Doc-4C §B.6; vehicle =
// the Doc-6A §10.3 dedicated dedup table per the owning-module design, Doc-6C §6.1; stored-result
// column set per Doc-5A §9.3). OPERATIONAL replay cache, NOT a domain aggregate (Doc-6A R2) — no
// FK (inert rows survive actor anonymization), no soft delete. The replay scope key
// (`command_dedup_scope_key_uq`, UNIQUE NULLS NOT DISTINCT over contract/actor/org/key — the
// poisoning guard) + RLS live raw-SQL-only in the `identity_command_dedup` migration (the house
// pattern for constraints Prisma cannot express — cf. the partial-unique-live indexes).
model CommandDedup {
  id              String   @id @db.Uuid
  contractId      String   @map("contract_id")
  actorUserId     String   @map("actor_user_id") @db.Uuid
  organizationId  String?  @map("organization_id") @db.Uuid
  idempotencyKey  String   @map("idempotency_key")
  responseStatus  Int      @map("response_status")
  responseBody    Json     @map("response_body") @db.JsonB
  responseHeaders Json?    @map("response_headers") @db.JsonB
  executedAt      DateTime @default(now()) @map("executed_at") @db.Timestamptz
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@map("command_dedup")
  @@schema("identity")
}

// ─────────────────────────────────────────────────────────────────────────────
// M7 — Monetization / Billing (`billing`) — Doc-6I (FROZEN)
//
// W3-BILL-1 [Wave-3 M7 pilot slice] realizes the Plans & Entitlements grouping
// (Doc-6I §3.1 — `plans` + `entitlements` + `plan_entitlements`): the platform-owned
// plan catalog behind the two authenticated Platform-Public reads
// `billing.get_plan.v1` / `billing.list_plans.v1` (Doc-4I §HB-1.4 / Doc-5I §4).
// Columns are [Doc-2 §10.8 binding]; physical specifics [Doc-6I §2.5]. Enums / RLS /
// composite-PK live raw-SQL in the `billing_plan_catalog_pilot` migration
// (tables/columns managed by Prisma). The logical `status` (draft|active|retired) is
// DERIVED, never a stored column (Doc-2 §10.8: `plans` carries no `status` — `is_active`
// + soft-delete `SD = retire`): retired ⟺ soft-deleted, active ⟺ is_active, draft otherwise.
//
// OUT OF SCOPE (land with their own M7 slices): subscriptions (+events), usage_ledger,
// lead_credit_accounts (+transactions), platform_invoices (+payments), reward_accounts
// (+transactions), referrals — Doc-6I §3.2–§3.6.
// ─────────────────────────────────────────────────────────────────────────────

// §3.1.1 — billing.plans (platform-owned marketing catalog; public-read + admin-write RLS).
model Plan {
  id           String       @id @db.Uuid
  name         String
  billingCycle BillingCycle @map("billing_cycle")
  price        Decimal      @db.Decimal
  currency     String       @default("BDT") @db.Char(3)
  isActive     Boolean      @default(false) @map("is_active")
  createdAt    DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime     @updatedAt @map("updated_at") @db.Timestamptz
  createdBy    String?      @map("created_by") @db.Uuid
  updatedBy    String?      @map("updated_by") @db.Uuid
  deletedAt    DateTime?    @map("deleted_at") @db.Timestamptz
  deletedBy    String?      @map("deleted_by") @db.Uuid
  deleteReason String?      @map("delete_reason")

  planEntitlements PlanEntitlement[]
  subscriptions    Subscription[]

  @@map("plans")
  @@schema("billing")
}

// §3.1.2 — billing.entitlements (typed catalog; `slug` UNIQUE; NO soft-delete — Doc-2 §10.8).
model Entitlement {
  id           String          @id @db.Uuid
  slug         String
  type         EntitlementType
  defaultValue Json?           @map("default_value") @db.JsonB
  createdAt    DateTime        @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime        @updatedAt @map("updated_at") @db.Timestamptz
  createdBy    String?         @map("created_by") @db.Uuid
  updatedBy    String?         @map("updated_by") @db.Uuid

  planEntitlements PlanEntitlement[]

  @@unique([slug], map: "entitlements_slug_uq")
  @@map("entitlements")
  @@schema("billing")
}

// §3.1.3 — billing.plan_entitlements (M:N per-plan value; composite PK; append/upsert — no SD, no updated_at).
model PlanEntitlement {
  planId        String   @map("plan_id") @db.Uuid
  entitlementId String   @map("entitlement_id") @db.Uuid
  valueJsonb    Json     @map("value_jsonb") @db.JsonB
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz
  createdBy     String?  @map("created_by") @db.Uuid

  plan        Plan        @relation(fields: [planId], references: [id], map: "plan_entitlements_plan_fk")
  entitlement Entitlement @relation(fields: [entitlementId], references: [id], map: "plan_entitlements_entitlement_fk")

  @@id([planId, entitlementId], map: "plan_entitlements_pkey")
  @@map("plan_entitlements")
  @@schema("billing")
}

enum BillingCycle {
  monthly
  annual

  @@map("billing_cycle")
  @@schema("billing")
}

// DB values are `'boolean' | 'numeric' | 'enum'` (Doc-2 §10.8 / Doc-6I). `enum` is a Prisma keyword,
// so its member is `enum_`, @map'd to the DB literal `enum`; the module maps client → wire string.
enum EntitlementType {
  boolean
  numeric
  enum_   @map("enum")

  @@map("entitlement_type")
  @@schema("billing")
}

// §3.2 — billing.subscriptions (Doc-6I §3.2.1 / Doc-2 §10.8 + §5.7) — org-tenant; one active per org
// (partial-unique WHERE state='active'; raw-SQL in the migration). W3-BILL-4.
model Subscription {
  id             String            @id @db.Uuid
  organizationId String            @map("organization_id") @db.Uuid
  planId         String            @map("plan_id") @db.Uuid
  state          SubscriptionState @default(pending_payment)
  periodStart    DateTime?         @map("period_start") @db.Timestamptz
  periodEnd      DateTime?         @map("period_end") @db.Timestamptz
  autoRenew      Boolean           @default(true) @map("auto_renew")
  createdAt      DateTime          @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime          @updatedAt @map("updated_at") @db.Timestamptz
  createdBy      String?           @map("created_by") @db.Uuid
  updatedBy      String?           @map("updated_by") @db.Uuid
  deletedAt      DateTime?         @map("deleted_at") @db.Timestamptz
  deletedBy      String?           @map("deleted_by") @db.Uuid
  deleteReason   String?           @map("delete_reason")

  plan   Plan                @relation(fields: [planId], references: [id], map: "subscriptions_plan_fk")
  events SubscriptionEvent[]

  @@map("subscriptions")
  @@schema("billing")
}

// §3.2.2 — billing.subscription_events (Doc-6I §3.2.2 / Doc-2 §10.8) — append-only (immutability trigger
// in the migration); NO soft-delete, NO updated_at.
model SubscriptionEvent {
  id             String                @id @db.Uuid
  subscriptionId String                @map("subscription_id") @db.Uuid
  eventType      SubscriptionEventType @map("event_type")
  occurredAt     DateTime              @default(now()) @map("occurred_at") @db.Timestamptz
  payloadJsonb   Json?                 @map("payload_jsonb") @db.JsonB
  createdAt      DateTime              @default(now()) @map("created_at") @db.Timestamptz
  createdBy      String?               @map("created_by") @db.Uuid

  subscription Subscription @relation(fields: [subscriptionId], references: [id], map: "subscription_events_subscription_fk")

  @@map("subscription_events")
  @@schema("billing")
}

enum SubscriptionState {
  pending_payment
  active
  expired

  @@map("subscription_state")
  @@schema("billing")
}

enum SubscriptionEventType {
  purchase
  renew
  expire
  cancel

  @@map("subscription_event_type")
  @@schema("billing")
}
