# iVendorz — environment variable template (WP-0.12 [W0-SEC-001]).
#
# Copy to `.env.local` and fill real values for local dev. NEVER commit real secrets —
# env vars only; secrets never in code/commits/logs (CLAUDE.md §2). `.env.local` (and all
# `.env*` except this template) are gitignored. This file lists NAMES only, no values.
#
# Real Supabase project + production secrets are wired at Wave 1 (deferred). For local dev
# the test harness uses the docker-compose Postgres (see docker-compose.yml).

# --- Database (Prisma / Supabase Postgres) ---------------------------------------------
# Pooled connection for the app runtime; DIRECT_URL is the direct (non-pooler) connection
# used for migrations (Prisma migrate must NOT go through the Supabase pgbouncer pooler).
DATABASE_URL=
DIRECT_URL=

# --- Supabase (Auth / Storage / Realtime) ----------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only privileged key — NEVER exposed to the browser bundle. Used by privileged
# server operations in later waves; not wired at bootstrap.
SUPABASE_SERVICE_ROLE_KEY=

# --- Inngest (async jobs) --------------------------------------------------------------
# Read by the Inngest SDK at runtime. SIGNING_KEY verifies request signatures and MUST be
# set in production before real job functions are registered (Wave 2).
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# --- Email (Resend) --------------------------------------------------------------------
RESEND_API_KEY=

# --- Analytics (PostHog) ---------------------------------------------------------------
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=

# --- AI (future activation — Claude + OpenAI) ------------------------------------------
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
