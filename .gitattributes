# Normalize line endings: deterministic across Windows/Linux (CI + local).
* text=auto eol=lf

# Shell scripts and git hooks must be LF (executed via git's bundled sh on Windows).
*.sh text eol=lf
.husky/pre-commit text eol=lf
.husky/pre-push text eol=lf

# Binary assets — never normalize.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.woff binary
*.woff2 binary
*.node binary
*.wasm binary
